# Images (optional overrides)
DIRECTUS_IMAGE=directus/directus:11
POSTGRES_IMAGE=postgres:16-alpine
MINIO_IMAGE=minio/minio:latest
GOTENBERG_IMAGE=gotenberg/gotenberg:8

# Directus
DIRECTUS_PUBLIC_URL=http://localhost:8055
DIRECTUS_KEY=replace-with-strong-random
DIRECTUS_SECRET=replace-with-strong-random
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=replace-with-strong-password
DIRECTUS_CORS_ORIGIN=http://localhost:5173

# Postgres
POSTGRES_DB=directus
POSTGRES_USER=directus
POSTGRES_PASSWORD=directus

# MinIO (S3-compatible private storage for dev)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=homeown-private

